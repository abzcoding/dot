adjust-cell-height = 25%
alpha-blending = linear-corrected
background = "#1e1e2e"
background-blur-radius = 40
background-opacity = 0.96
clipboard-trim-trailing-spaces = true
cursor-style = block
cursor-style-blink = false
custom-shader = shaders/cursor_warp.glsl
custom-shader-animation = always
font-codepoint-map = U+E900-U+E959=mini-file-icons
font-codepoint-map = U+E95D-U+E95E=mini-file-icons
font-codepoint-map = U+E961-U+E962=mini-file-icons
font-family = "FiraCode Nerd Font"
font-family = "mini-file-icons"
font-family-bold = "FiraCode Nerd Font"
font-family-bold-italic = "Iosevka NF"
font-family-italic = "Iosevka NF"
font-feature = "+zero"
font-size = 13
font-style-bold = "Medium"
font-style-bold-italic = "Medium"
font-style-italic = "Regular"
foreground = "#a9b1d6"
fullscreen = non-native-visible-menu
gtk-titlebar = false
link-url = true
macos-auto-secure-input = true
macos-hidden = always
macos-non-native-fullscreen = true
macos-option-as-alt = true
macos-secure-input-indication = true
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = hidden
mouse-hide-while-typing = true
shell-integration-features = no-cursor
theme = catppuccin-mocha
window-inherit-font-size = true
window-inherit-working-directory = true
window-padding-balance = true
window-padding-color = extend
window-padding-x = 6
window-padding-y = 6
window-save-state = never
window-step-resize = true
window-theme = system
